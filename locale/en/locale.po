msgid "plugins.generic.reviewerCertificate.displayName"
msgstr "Reviewer Certificate Plugin"

msgid "plugins.generic.reviewerCertificate.description"
msgstr "Generates a printable appreciation certificate for reviewers who have completed their peer-review assignment."

msgid "plugins.generic.reviewerCertificate.certificate.title"
msgstr "Certificate of Appreciation"

msgid "plugins.generic.reviewerCertificate.certificate.print"
msgstr "Print / Save as PDF"

msgid "plugins.generic.reviewerCertificate.certificate.heading"
msgstr "Certificate of Appreciation"

msgid "plugins.generic.reviewerCertificate.certificate.subheading"
msgstr "Peer Review Recognition"

msgid "plugins.generic.reviewerCertificate.certificate.presentedTo"
msgstr "This certificate is proudly presented to"

msgid "plugins.generic.reviewerCertificate.certificate.body"
msgstr "In grateful recognition of the time, expertise, and dedication contributed as a peer reviewer for <em>{$journalName}</em>. This certificate acknowledges the successful completion of a review for the manuscript titled <strong>{$submissionTitle}</strong>."

msgid "plugins.generic.reviewerCertificate.certificate.completedOn"
msgstr "Review completed on:"

msgid "plugins.generic.reviewerCertificate.certificate.editorSignature"
msgstr "Editor-in-Chief"

msgid "plugins.generic.reviewerCertificate.certificate.date"
msgstr "Date"

msgid "plugins.generic.reviewerCertificate.settings.description"
msgstr "Configure the information displayed on reviewer certificates."

msgid "plugins.generic.reviewerCertificate.settings.previewSection"
msgstr "Certificate Preview"

msgid "plugins.generic.reviewerCertificate.settings.previewReviewId"
msgstr "Review ID:"

msgid "plugins.generic.reviewerCertificate.settings.previewButton"
msgstr "Preview"

msgid "plugins.generic.reviewerCertificate.settings.previewOpenTab"
msgstr "Open in new tab"

msgid "plugins.generic.reviewerCertificate.settings.previewLoading"
msgstr "Loading certificate..."

msgid "plugins.generic.reviewerCertificate.settings.previewHelp"
msgstr "Enter any completed review ID to preview the certificate with current settings. URL:"

msgid "plugins.generic.reviewerCertificate.settings.editorSection"
msgstr "Editor-in-Chief"

msgid "plugins.generic.reviewerCertificate.settings.editorName"
msgstr "Editor-in-Chief Name"

msgid "plugins.generic.reviewerCertificate.settings.editorTitle"
msgstr "Editor Title (shown under signature)"

msgid "plugins.generic.reviewerCertificate.settings.editorNameFontSize"
msgstr "Name Font Size"

msgid "plugins.generic.reviewerCertificate.settings.editorNameColor"
msgstr "Name Color"

msgid "plugins.generic.reviewerCertificate.settings.journalNameSection"
msgstr "Journal Name Appearance"

msgid "plugins.generic.reviewerCertificate.settings.journalNameFontSize"
msgstr "Journal Name Font Size"

msgid "plugins.generic.reviewerCertificate.settings.journalNameColor"
msgstr "Journal Name Color"

msgid "plugins.generic.reviewerCertificate.settings.themeSection"
msgstr "Color Theme"

msgid "plugins.generic.reviewerCertificate.settings.themePresets"
msgstr "Quick presets:"

msgid "plugins.generic.reviewerCertificate.settings.themePresetsHelp"
msgstr "Clicking a preset fills all three color fields below. You can still adjust them individually."

msgid "plugins.generic.reviewerCertificate.settings.themeGold"
msgstr "Classic Gold"

msgid "plugins.generic.reviewerCertificate.settings.themeBlue"
msgstr "Blue Academic"

msgid "plugins.generic.reviewerCertificate.settings.themeDark"
msgstr "Minimal Dark"

msgid "plugins.generic.reviewerCertificate.settings.themeEmerald"
msgstr "Emerald"

msgid "plugins.generic.reviewerCertificate.settings.accentColor"
msgstr "Accent Color (borders & ornaments)"

msgid "plugins.generic.reviewerCertificate.settings.textColor"
msgstr "Text Color"

msgid "plugins.generic.reviewerCertificate.settings.textColorHelp"
msgstr "Color of the main certificate text (heading, recipient name and body)."

msgid "plugins.generic.reviewerCertificate.settings.bodySection"
msgstr "Certificate Body Text"

msgid "plugins.generic.reviewerCertificate.settings.certificateBody"
msgstr "Custom body text"

msgid "plugins.generic.reviewerCertificate.settings.certificateBodyPlaceholder"
msgstr "In recognition of your time and expertise as a reviewer for {journalName}, and in acknowledgment of completing the review of {submissionTitle}."

msgid "plugins.generic.reviewerCertificate.settings.certificateBodyHelp"
msgstr "Write the body paragraph of the certificate. Use {journalName} and {submissionTitle} as placeholders — they will be replaced with the actual values. Leave blank to use the default translated text."

msgid "plugins.generic.reviewerCertificate.settings.emailSection"
msgstr "Email Notification"

msgid "plugins.generic.reviewerCertificate.settings.sendEmail"
msgstr "Email the certificate to the reviewer when an editor thanks them"

msgid "plugins.generic.reviewerCertificate.settings.sendEmailHelp"
msgstr "When disabled, no email is sent. The certificate is still generated and stays available from the reviewer's review page and the My Certificates page."

msgid "plugins.generic.reviewerCertificate.settings.qrSection"
msgstr "QR Code"

msgid "plugins.generic.reviewerCertificate.settings.enableQrCode"
msgstr "Show QR code on certificate for instant verification"

msgid "plugins.generic.reviewerCertificate.settings.qrHelp"
msgstr "A small QR code linking back to this certificate URL will be printed in the bottom-right corner. Anyone scanning it can verify the certificate is authentic."

msgid "plugins.generic.reviewerCertificate.settings.qrSize"
msgstr "QR Code Size"

msgid "plugins.generic.reviewerCertificate.settings.qrOffsetX"
msgstr "QR Code Offset X"

msgid "plugins.generic.reviewerCertificate.settings.qrOffsetY"
msgstr "QR Code Offset Y"

msgid "plugins.generic.reviewerCertificate.settings.pdfSection"
msgstr "PDF Download (Server-side)"

msgid "plugins.generic.reviewerCertificate.settings.wkhtmltopdfPath"
msgstr "wkhtmltopdf binary path (optional)"

msgid "plugins.generic.reviewerCertificate.settings.wkhtmltopdfHelp"
msgstr "Leave blank to auto-detect. Provide the full path (e.g. /usr/bin/wkhtmltopdf) if auto-detection fails. When configured, a red \"Download PDF\" button appears on the certificate page for a one-click, print-ready PDF."

msgid "plugins.generic.reviewerCertificate.settings.wkhtmltopdfFound"
msgstr "wkhtmltopdf detected"

msgid "plugins.generic.reviewerCertificate.settings.wkhtmltopdfNotFound"
msgstr "wkhtmltopdf not found. Install it to enable server-side PDF downloads."

msgid "plugins.generic.reviewerCertificate.settings.signatureSection"
msgstr "Signature Image"

msgid "plugins.generic.reviewerCertificate.settings.signatureUrl"
msgstr "Signature Image URL"

msgid "plugins.generic.reviewerCertificate.settings.signatureUrlHelp"
msgstr "Enter the full URL of the signature image (PNG or JPG with transparent background recommended). Leave blank to show an empty signature line."

msgid "plugins.generic.reviewerCertificate.settings.logoSection"
msgstr "Journal Logo"

msgid "plugins.generic.reviewerCertificate.settings.customLogoUrl"
msgstr "Custom Logo URL (optional)"

msgid "plugins.generic.reviewerCertificate.settings.customLogoUrlHelp"
msgstr "Enter a custom logo URL to override the journal's default logo. Leave blank to use the journal logo configured in Website Settings."

msgid "plugins.generic.reviewerCertificate.settings.uploadImage"
msgstr "Upload Image"

msgid "plugins.generic.reviewerCertificate.settings.imageSize"
msgstr "Display Size (height)"

msgid "plugins.generic.reviewerCertificate.settings.uploadHelp"
msgstr "Click or drag and drop a JPEG, PNG, GIF, or WebP image."

msgid "plugins.generic.reviewerCertificate.settings.backgroundSection"
msgstr "Certificate Background"

msgid "plugins.generic.reviewerCertificate.settings.backgroundImageUrl"
msgstr "Background Image URL (optional)"

msgid "plugins.generic.reviewerCertificate.settings.backgroundImageUrlHelp"
msgstr "Enter the URL of an image to use as the certificate background. Leave blank for a plain white background."

msgid "plugins.generic.reviewerCertificate.settings.backgroundSizeTitle"
msgstr "Optimal image size"

msgid "plugins.generic.reviewerCertificate.settings.backgroundSizeRecommended"
msgstr "Recommended:"

msgid "plugins.generic.reviewerCertificate.settings.backgroundSizeRatio"
msgstr "(A4 landscape ratio, retina quality)"

msgid "plugins.generic.reviewerCertificate.settings.backgroundSizeHint"
msgstr "Certificate is displayed at"

msgid "plugins.generic.reviewerCertificate.email.certificateSubject"
msgstr "Your Certificate of Appreciation is Ready"

msgid "plugins.generic.reviewerCertificate.email.certificateLabel"
msgstr "Download Your Certificate"

msgid "plugins.generic.reviewerCertificate.email.certificateNotice"
msgstr "Thank you for completing your review. You can now download your Certificate of Appreciation by clicking the button below."

msgid "plugins.generic.reviewerCertificate.certificate.verify"
msgstr "Verify"

msgid "plugins.generic.reviewerCertificate.certificate.downloadPdf"
msgstr "Download PDF"

msgid "plugins.generic.reviewerCertificate.certificate.downloadImage"
msgstr "Download as Image"

msgid "plugins.generic.reviewerCertificate.certificate.downloadPdfServer"
msgstr "Download PDF (Server)"

msgid "plugins.generic.reviewerCertificate.certificate.generating"
msgstr "Generating..."

msgid "plugins.generic.reviewerCertificate.certificate.downloadLink"
msgstr "Download Your Certificate of Appreciation"

msgid "plugins.generic.reviewerCertificate.certificate.viewAllLink"
msgstr "View all your certificates"

msgid "plugins.generic.reviewerCertificate.list.title"
msgstr "My Certificates"

msgid "plugins.generic.reviewerCertificate.list.heading"
msgstr "My Certificates of Appreciation"

msgid "plugins.generic.reviewerCertificate.list.colSubmission"
msgstr "Manuscript"

msgid "plugins.generic.reviewerCertificate.list.colDate"
msgstr "Review completed"

msgid "plugins.generic.reviewerCertificate.list.colActions"
msgstr "Certificate"

msgid "plugins.generic.reviewerCertificate.list.view"
msgstr "View"

msgid "plugins.generic.reviewerCertificate.list.empty"
msgstr "You don't have any certificates yet. Certificates become available once you complete a review and the editor sends a thank-you."

msgid "plugins.generic.reviewerCertificate.list.searchPlaceholder"
msgstr "Search by manuscript title…"

msgid "plugins.generic.reviewerCertificate.list.search"
msgstr "Search"

msgid "plugins.generic.reviewerCertificate.list.clear"
msgstr "Clear"

msgid "plugins.generic.reviewerCertificate.list.showing"
msgstr "Showing {$start}–{$end} of {$total}"

msgid "plugins.generic.reviewerCertificate.list.noResults"
msgstr "No certificates match “{$query}”."

msgid "plugins.generic.reviewerCertificate.list.prev"
msgstr "Previous"

msgid "plugins.generic.reviewerCertificate.list.next"
msgstr "Next"

msgid "plugins.generic.reviewerCertificate.error.title"
msgstr "Certificate Unavailable"

msgid "plugins.generic.reviewerCertificate.error.notCompleted"
msgstr "This certificate cannot be issued because the review assignment has not been completed yet."

msgid "plugins.generic.reviewerCertificate.settings.dateFormatSection"
msgstr "Date Format"

msgid "plugins.generic.reviewerCertificate.settings.dateFormat"
msgstr "Choose how dates appear on the certificate"

msgid "plugins.generic.reviewerCertificate.settings.dateFormatLong"
msgstr "Locale long (e.g. August 15, 2026)"

msgid "plugins.generic.reviewerCertificate.settings.dateFormatMedium"
msgstr "Locale medium (e.g. Aug 15, 2026)"

msgid "plugins.generic.reviewerCertificate.settings.dateFormatShort"
msgstr "Locale short (e.g. 8/15/26)"

msgid "plugins.generic.reviewerCertificate.settings.dateFormatHelp"
msgstr "Select how dates are displayed on the certificate. Locale formats adapt automatically to the journal language."

msgid "plugins.generic.reviewerCertificate.settings.dateLocale"
msgstr "Date locale (regional month names)"

msgid "plugins.generic.reviewerCertificate.settings.dateLocaleAuto"
msgstr "Auto (use journal language)"

msgid "plugins.generic.reviewerCertificate.settings.dateLocaleHelp"
msgstr "Month names differ by country (e.g. August = أغسطس in some countries but اب in Iraq). Select the country whose month names you prefer, or leave as Auto to use the journal's language setting."

msgid "plugins.generic.reviewerCertificate.settings.positionSection"
msgstr "Signature & Date Position"

msgid "plugins.generic.reviewerCertificate.settings.positionHelp"
msgstr "Fine-tune where the Editor-in-Chief and Date blocks sit on the certificate. Use negative values to move up/left and positive values to move down/right. All values are in pixels."

msgid "plugins.generic.reviewerCertificate.settings.signatureSectionOffsetY"
msgstr "Move both blocks up/down"

msgid "plugins.generic.reviewerCertificate.settings.signatureSectionPaddingTop"
msgstr "Space above signature row"

msgid "plugins.generic.reviewerCertificate.settings.signatureSectionGap"
msgstr "Gap between blocks"

msgid "plugins.generic.reviewerCertificate.settings.editorBlockOffsetX"
msgstr "Editor-in-Chief — left/right"

msgid "plugins.generic.reviewerCertificate.settings.editorBlockOffsetY"
msgstr "Editor-in-Chief — up/down"

msgid "plugins.generic.reviewerCertificate.settings.dateBlockOffsetX"
msgstr "Date — left/right"

msgid "plugins.generic.reviewerCertificate.settings.dateBlockOffsetY"
msgstr "Date — up/down"

msgid "plugins.generic.reviewerCertificate.settings.visibilitySection"
msgstr "Show / Hide & Move Elements"

msgid "plugins.generic.reviewerCertificate.settings.visibilityHelp"
msgstr "Uncheck any element to hide it from the certificate. Use the offset below to move all certificate text up or down together."

msgid "plugins.generic.reviewerCertificate.settings.showLogo"
msgstr "Journal logo"

msgid "plugins.generic.reviewerCertificate.settings.showJournalName"
msgstr "Journal name"

msgid "plugins.generic.reviewerCertificate.settings.showDividers"
msgstr "Divider lines"

msgid "plugins.generic.reviewerCertificate.settings.showHeading"
msgstr "Heading (Certificate of Reviewing)"

msgid "plugins.generic.reviewerCertificate.settings.showSubheading"
msgstr "Subheading"

msgid "plugins.generic.reviewerCertificate.settings.showPresentedTo"
msgstr "“Presented to” label"

msgid "plugins.generic.reviewerCertificate.settings.showReviewerName"
msgstr "Reviewer name"

msgid "plugins.generic.reviewerCertificate.settings.showBody"
msgstr "Body text"

msgid "plugins.generic.reviewerCertificate.settings.showDateLine"
msgstr "Completed-on date line"

msgid "plugins.generic.reviewerCertificate.settings.showSignatureSection"
msgstr "Signature & date section"

msgid "plugins.generic.reviewerCertificate.settings.contentOffsetY"
msgstr "Move all certificate text up/down"

msgid "plugins.generic.reviewerCertificate.settings.contentOffsetYHelp"
msgstr "Shifts the entire text block vertically. Negative values move everything up, positive values move it down (pixels, −400 to 400)."

msgid "plugins.generic.reviewerCertificate.settings.textOverrideSection"
msgstr "Element Text (optional)"

msgid "plugins.generic.reviewerCertificate.settings.textOverrideHelp"
msgstr "Replace the wording of individual certificate elements. Leave a field blank to keep the built-in default. Each language can have its own text."

msgid "plugins.generic.reviewerCertificate.settings.journalNameText"
msgstr "Journal name (blank = use the journal's name)"

msgid "plugins.generic.reviewerCertificate.settings.headingText"
msgstr "Heading (blank = “Certificate of Reviewing”)"

msgid "plugins.generic.reviewerCertificate.settings.subheadingText"
msgstr "Subheading"

msgid "plugins.generic.reviewerCertificate.settings.presentedToText"
msgstr "“Presented to” label"

msgid "plugins.generic.reviewerCertificate.settings.completedOnText"
msgstr "“Completed on” label (appears before the date)"

msgid "plugins.generic.reviewerCertificate.settings.dateLabelText"
msgstr "Date label (under the signature line)"
